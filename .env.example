APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------------------------------------------------------------------------
# Pipeline mode selector
# ---------------------------------------------------------------------------
# demo  -> deterministic, no credentials, no extra deps (used on Render + tests)
# azure -> real Azure OpenAI deployment
# llama -> local OpenAI-compatible server (e.g. Ollama / llama.cpp)
# For azure/llama: pip install -r requirements-llm.txt
LLM_MODE=demo

# --- Azure OpenAI (LLM_MODE=azure) -----------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Local Llama (LLM_MODE=llama) ------------------------------------------
# Ollama default exposes an OpenAI-compatible API at http://localhost:11434/v1
LLAMA_BASE_URL=http://localhost:11434/v1
LLAMA_MODEL=llama3.1
LLAMA_API_KEY=ollama

# --- Shared generation parameters ------------------------------------------
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700
LLM_TIMEOUT_SECONDS=60

